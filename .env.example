# --- MongoDB (Atlas or self-hosted on your VPS) ---
# Atlas:  mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
# VPS:    mongodb://USER:PASS@127.0.0.1:27017/?authSource=admin
MONGODB_URI=
MONGODB_DB=clawmarket
MONGODB_COLLECTION=skills
# Name of the Atlas Vector Search index created by `npm run seed`.
MONGODB_VECTOR_INDEX=vector_index

# --- Gemini (Google AI Studio key, or Vertex). Optional. ---
# Powers (a) embeddings for Atlas Vector Search and (b) rerank + reason generation.
# If unset, the matcher falls back to deterministic keyword ranking (demo still works).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# --- Live ClawMarket catalog source (used by the seed script) ---
CLAWMARKET_BASE_URL=https://clawmarketai.com

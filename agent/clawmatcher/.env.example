# ADK agent config. Copy to .env and fill in (this file is safe to commit; .env is not).

# AI Studio key — google-genai reads GOOGLE_API_KEY. Same key as the web app.
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GEMINI_MODEL=gemini-2.5-flash

# To use Vertex AI instead of an AI Studio key, set:
#   GOOGLE_GENAI_USE_VERTEXAI=TRUE
#   GOOGLE_CLOUD_PROJECT=your-project-id
#   GOOGLE_CLOUD_LOCATION=us-central1
# (and authenticate with `gcloud auth application-default login`)

# MongoDB MCP server target (same Atlas cluster the web app seeds).
MDB_MCP_CONNECTION_STRING=
MONGODB_DB=clawmarket
MONGODB_COLLECTION=skills
